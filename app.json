{
  "expo": {
    "name": "ManyHandz",
    "slug": "manyhandz",
    "scheme": "manyhandz",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.criterial.manyhandz",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.criterial.manyhandz",
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "monochromeImage": "./assets/images/adaptive-icon-monochrome.png",
        "backgroundColor": "#0a0e1a"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "$(PRODUCT_NAME) accesses your photos so you can attach chore proof and avatars.",
          "cameraPermission": "$(PRODUCT_NAME) uses the camera to take before/after chore photos."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "$(PRODUCT_NAME) uses Face ID to lock the app and protect kid accounts."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#FF6B4A"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-calendar",
        {
          "calendarPermission": "$(PRODUCT_NAME) adds chore schedules to your calendar."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0a0e1a"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6cef9f47-3632-4b5e-a0fb-0357dbbcd3d4"
      }
    },
    "runtimeVersion": "1.2.0",
    "icon": "./assets/images/icon.png",
    "owner": "wlarson"
  }
}
