{
  "name": "manyhandz",
  "private": true,
  "version": "0.2.0",
  "main": "expo-router/entry",
  "type": "commonjs",
  "description": "ManyHandz — household chore management for families and roommates. Expo (React Native) native-first + Cloudflare Workers (Hono) + Neon (Drizzle) + Better-Auth.",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "export:web": "expo export --platform web",
    "typecheck": "tsc --noEmit",
    "typecheck:worker": "npm --prefix worker run typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "cf:dev": "npm --prefix worker run dev",
    "deploy": "npm run export:web && npm --prefix worker run deploy",
    "db:generate": "npm --prefix worker run db:generate",
    "db:migrate": "npm --prefix worker run db:migrate",
    "db:studio": "npm --prefix worker run db:studio",
    "eas:build:ios": "eas build --platform ios",
    "eas:build:android": "eas build --platform android",
    "eas:submit:ios": "eas submit --platform ios",
    "eas:submit:android": "eas submit --platform android",
    "eas:update": "eas update",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@better-auth/expo": "^1.6.14",
    "@better-auth/passkey": "^1.6.14",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/metro-runtime": "~56.0.14",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^0.10.4",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@shopify/react-native-skia": "2.6.2",
    "@simplewebauthn/server": "^13.2.0",
    "@tanstack/query-async-storage-persister": "^5.101.0",
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-query-persist-client": "^5.101.0",
    "better-auth": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "expo": "^56.0.9",
    "expo-audio": "~56.0.11",
    "expo-calendar": "~56.0.8",
    "expo-constants": "~56.0.17",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.19",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.10",
    "expo-image-picker": "~56.0.16",
    "expo-keep-awake": "~56.0.3",
    "expo-linking": "~56.0.13",
    "expo-local-authentication": "~56.0.4",
    "expo-localization": "~56.0.6",
    "expo-location": "~56.0.16",
    "expo-network": "~56.0.5",
    "expo-notifications": "~56.0.16",
    "expo-print": "~56.0.4",
    "expo-router": "~56.2.9",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.20",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-store-review": "~56.0.3",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.18",
    "expo-web-browser": "~56.0.5",
    "hono": "^4.6.14",
    "lucide-react-native": "^1.17.0",
    "moti": "^0.30.0",
    "nativewind": "^4.2.5",
    "openai": "^6.27.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.71.2",
    "react-native": "^0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-maps": "1.27.2",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "^4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "^4.25.2",
    "react-native-svg": "^15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "^0.8.3",
    "resend": "^6.9.0",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0",
    "victory-native": "^41.25.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "overrides": {
    "kysely": "0.28.17"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@expo/ngrok": "^4.1.3",
    "@types/node": "^22.10.0",
    "@types/react": "~19.2.0",
    "eslint": "^9.17.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
