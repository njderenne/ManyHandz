# ==============================================================================
# Reference env for a minted app — produced from
# builder/provision/env-manifest.js by generate-env.js. Grouped by TIER (who supplies the
# value) and tagged with SURFACE (where it is read). Keep values UNQUOTED.
# Run `node builder/provision/generate-env.js --app <app>` to fill ① + ② automatically.
# ==============================================================================

# ─── STUDIO-SHARED  -  one value reused by every app (injected from the vault by generate-env.js) ───
# Worker secret · required · auth emails: reset / verify / invites
RESEND_API_KEY=
# Worker secret · required · studio-standard sender (display name derived from APP_CONFIG.name)
EMAIL_FROM=
# Worker secret · feature:ai · reason + complex AI tiers (worker/ai)
ANTHROPIC_API_KEY=
# Worker secret · feature:ai · classify AI tier
OPENAI_API_KEY=
# Worker secret · feature:ai · vision + image tiers; ALSO read by generate-icons / generate-marketing
XAI_API_KEY=
# Worker secret · feature:voice · TTS / STT
ELEVENLABS_API_KEY=
# Worker secret · optional · background removal (rembg.com) — or REPLICATE_API_TOKEN / REMBG_SERVICE_URL
REMBG_API_KEY=
# Worker secret · optional · background-removal fallback (Replicate)
REPLICATE_API_TOKEN=
# EAS build var (native manifest, build-time) · feature:maps · Android maps — baked into the native manifest at BUILD time; set as an EAS env var, NOT a worker secret
GOOGLE_MAPS_API_KEY=

# ─── PER-APP  -  generated or provisioned during the mint ───
# Worker secret · required · Neon project (create-db.js)
DATABASE_URL=
# Worker secret · required · session signing secret (= openssl rand -base64 32)
BETTER_AUTH_SECRET=
# Worker secret · required · the deployed Worker URL (auth callbacks + email links)
BETTER_AUTH_URL=
# EXPO_PUBLIC (client bundle, build-time) · required · the deployed Worker URL — inlined into the client at build time
EXPO_PUBLIC_API_URL=

# ─── PER-APP  -  created by hand in a 3rd-party dashboard (fill these in) ───
# Worker secret · feature:auth.google · NEW per-app OAuth client (MINT §4 recipe) — never reuse another app's
GOOGLE_CLIENT_ID=
# Worker secret · feature:auth.google · same OAuth client
GOOGLE_CLIENT_SECRET=
# Worker secret · feature:auth.apple · per-app Apple service id
APPLE_CLIENT_ID=
# Worker secret · feature:auth.apple · per-app Apple key (.p8 -> JWT)
APPLE_CLIENT_SECRET=
# Worker secret · feature:billing · Stripe account secret (test mode for a dry run)
STRIPE_SECRET_KEY=
# Worker secret · feature:billing · per-app webhook endpoint signing secret
STRIPE_WEBHOOK_SECRET=
# Worker secret · feature:billing · per-app product price id
STRIPE_PRICE_STANDARD=
# Worker secret · feature:billing · per-app product price id
STRIPE_PRICE_PREMIUM=
# EXPO_PUBLIC (client bundle, build-time) · feature:billing · Stripe publishable key — inlined at build time
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# EXPO_PUBLIC (client bundle, build-time) · feature:billing · paywall UI price (mirror of STRIPE_PRICE_STANDARD)
EXPO_PUBLIC_STRIPE_PRICE_STANDARD=
# EXPO_PUBLIC (client bundle, build-time) · feature:billing · paywall UI price (mirror of STRIPE_PRICE_PREMIUM)
EXPO_PUBLIC_STRIPE_PRICE_PREMIUM=

# ─── Optional Worker overrides (model/voice tuning) — set only to override a code default ───
# AI_CLASSIFY_MODEL= · AI_REASON_MODEL= · AI_COMPLEX_MODEL= · AI_VISION_MODEL= · AI_IMAGE_MODEL=
# ELEVENLABS_VOICE_ID= · ELEVENLABS_TTS_MODEL= · ELEVENLABS_STT_MODEL= · REMBG_SERVICE_URL= · REMBG_SERVICE_KEY=
